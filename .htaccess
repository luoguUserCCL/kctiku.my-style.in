# kcTiKu 题目管理系统 - URL 重写规则

# 启用重写引擎
RewriteEngine On

# 如果请求的是真实文件或目录，直接访问
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# API 路由重写
RewriteRule ^api/pools/([0-9]+)$ api/pools.php/$1 [L]
RewriteRule ^api/pools$ api/pools.php [L]
RewriteRule ^api/questions/move$ api/questions.php/move [L]
RewriteRule ^api/questions/([0-9]+)$ api/questions.php/$1 [L]
RewriteRule ^api/questions$ api/questions.php [L]
RewriteRule ^api/settings$ api/settings.php [L]

# 禁止访问敏感文件
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# 禁止访问配置文件
<FilesMatch "config\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# 设置默认字符集
AddDefaultCharset UTF-8

# PHP 设置
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
</IfModule>
